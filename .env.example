# --- Backend ---
# Provider for market rates: "mock" (deterministic 2026 rates) or "live" (API Ninjas)
RATE_PROVIDER_TYPE=mock

# Required when RATE_PROVIDER_TYPE=live. Get a key at https://api-ninjas.com
API_NINJAS_KEY=

# Cache TTL for rate-provider results (seconds)
RATES_CACHE_TTL_SECONDS=3600

# Comma-separated list of allowed CORS origins for the FastAPI app
CORS_ORIGINS=http://localhost:5173

# --- Advisor LLM narrative ---
# Narrative is generated by a local Ollama server. OLLAMA_BASE_URL defaults to
# http://host.docker.internal:11434 (the host machine from inside Docker).
# If unset / unreachable, the backend serves a deterministic templated
# narrative (narrative_source=fallback) and the UI shows an amber "live advisor
# offline" ribbon. Models are discovered dynamically via /api/tags and picked
# by the user in the UI.
OLLAMA_BASE_URL=http://host.docker.internal:11434
ADVISOR_NARRATIVE_ENABLED=true
ADVISOR_MAX_OUTPUT_TOKENS=800

# --- Frontend ---
# Base URL the React app uses to reach the API. In dev this points to the
# backend container exposed on the host; in prod nginx proxies /api so this is "/api".
VITE_API_BASE_URL=http://localhost:8000

# Comma-separated extra hostnames Vite's dev server should accept (required when
# serving the dev stack behind a reverse proxy / custom domain). Use "*" or
# "all" to disable the host check. Leave empty for the Vite default (localhost).
# Example: VITE_ALLOWED_HOSTS=finad.local.wonkylabz.com,other.host
VITE_ALLOWED_HOSTS=
